+    // MARK: - Fallback Entry
+
+    private func getFallbackTimelineEntry(for complication: CLKComplication, at date: Date) -> CLKComplicationTimelineEntry? {
+        let loopManager = ExtensionDelegate.shared().loopManager
+
+        // Try to get the last stored glucose value
+        let glucoseStore = loopManager.glucoseStore
+        var lastGlucose: StoredGlucoseSample?
+
+        let group = DispatchGroup()
+        group.enter()
+
+        glucoseStore.getGlucoseSamples(start: Date(timeIntervalSinceNow: -.hours(3))) { result in
+            if case .success(let samples) = result {
+                lastGlucose = samples.last
+            }
+            group.leave()
+        }
+
+        group.wait()
+
+        guard let glucose = lastGlucose else {
+            self.log.default("No fallback glucose data available")
+            return nil
+        }
+
+        // Create a minimal context with just the glucose data
+        var fallbackContext = WatchContext()
+        fallbackContext.glucose = glucose.quantity
+        fallbackContext.glucoseDate = glucose.startDate
+        fallbackContext.glucoseTrend = glucose.trend
+        fallbackContext.glucoseTrendRate = glucose.trendRate
+        fallbackContext.displayGlucoseUnit = loopManager.displayGlucoseUnit
+
+        if let template = CLKComplicationTemplate.templateForFamily(
+            complication.family,
+            from: fallbackContext,
+            at: date,
+            recencyInterval: LoopCoreConstants.inputDataRecencyInterval,
+            chartGenerator: self.makeChart)
+        {
+            switch complication.family {
+            case .graphicRectangular:
+                break
+            default:
+                template.tintColor = .gray  // Gray tint to indicate stale data
+            }
+
+            self.log.default("Returning fallback entry with glucose: %{public}@", String(describing: glucose.quantity))
+            return CLKComplicationTimelineEntry(date: date, complicationTemplate: template)
+        }
+
+        return nil
+    }
+
